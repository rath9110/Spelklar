# Database
DATABASE_URL=file:./prisma/spelklar.db

# JWT Secret – Change this to a random string in production
JWT_SECRET=your-secret-key-here-change-in-production

# 46elks SMS API credentials (optional in development)
# Get these from https://46elks.com/dashboard
SMS_USERNAME=your-46elks-api-username
SMS_PASSWORD=your-46elks-api-password

# Cloudflare R2 (optional in development)
# Get these from your Cloudflare dashboard
# Without R2, photos will be stored in demo mode (local only)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=spelklar-photos

# Environment
NODE_ENV=development

# Frontend URL for CORS (set on Render)
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Server port
PORT=3001
