datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  phone        String?  @unique
  email        String?  @unique
  displayName  String?
  role         String   @default("visitor")
  follows      Follow[]
  photos       Photo[]
  consents     PhotoConsent[]
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?
}

model Team {
  id        String   @id @default(cuid())
  name      String
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  follows   Follow[]
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  createdAt DateTime @default(now())
}

model Follow {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, teamId])
}

model Club {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  teams     Team[]
  createdAt DateTime @default(now())
}

model Match {
  id           String   @id
  homeTeamId   String?
  awayTeamId   String?
  homeTeam     Team?    @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team?    @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore    Int      @default(0)
  awayScore    Int      @default(0)
  timerSeconds Int      @default(0)
  status       String   @default("pre")
  events       MatchEvent[]
  photos       Photo[]
  createdAt    DateTime @default(now())
  endedAt      DateTime?

  // For backward compatibility: store team names if no team IDs
  homeTeamName String?
  awayTeamName String?
}

model MatchEvent {
  id           String   @id @default(cuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type         String
  team         String?
  player       String?
  note         String?
  timerSeconds Int
  timestamp    DateTime @default(now())
}

model Photo {
  id           String   @id @default(cuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  uploaderId   String
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  storageKey   String                  // R2 object key
  thumbnailKey String?                 // Compressed thumbnail key
  caption      String?
  status       String   @default("pending") // pending | approved | rejected | deleted
  moderatedBy  String?                 // userId of moderator
  moderatedAt  DateTime?
  consents     PhotoConsent[]
  createdAt    DateTime @default(now())
  deletedAt    DateTime?               // Soft delete for GDPR

  @@index([matchId])
  @@index([uploaderId])
  @@index([status])
}

model PhotoConsent {
  id        String   @id @default(cuid())
  photoId   String
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  grantedBy String                    // userId of consenting parent
  user      User     @relation(fields: [grantedBy], references: [id], onDelete: Cascade)
  scope     String   @default("match") // match | club | public
  grantedAt DateTime @default(now())
  revokedAt DateTime?

  @@unique([photoId, grantedBy])
  @@index([photoId])
}
